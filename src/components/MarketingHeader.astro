---
interface NavItem {
  label: string;
  href: string;
}

interface BrandTextSegment {
  text: string;
  color: string;
  fontWeight?: string;
}

interface Props {
  brandName: string;
  brandGradient?: string;
  brandLogoSrc: string;
  brandTextSegments?: BrandTextSegment[];
  brandTextSegmentsDark?: BrandTextSegment[];
  homeHref?: string;
  navItems: NavItem[];
  ctaLabel?: string;
  ctaHref?: string;
  signInLabel?: string;
  signInHref?: string;
  headerBgClass?: string;
  currentPath?: string;
  extraSlot?: boolean;
  languages?: Record<string, string>;
  currentLang?: string;
  defaultLang?: string;
}

const {
  brandName,
  brandGradient = 'from-blue-600 to-indigo-600',
  brandLogoSrc,
  brandTextSegments,
  brandTextSegmentsDark,
  navItems,
  ctaLabel,
  ctaHref,
  signInLabel,
  signInHref,
  headerBgClass = 'bg-white/80 dark:bg-slate-900/80',
  currentPath = '',
  currentLang,
  defaultLang = 'en',
  languages,
} = Astro.props;

// Compute locale-aware home href
const homeHref = Astro.props.homeHref ?? (currentLang && currentLang !== defaultLang ? `/${currentLang}/` : '/');

// Language switcher logic (only when i18n is enabled)
const hasI18n = languages && currentLang && Object.keys(languages).length > 1;
let switchUrl = '';
let otherLangLabel = '';
if (hasI18n) {
  const langKeys = Object.keys(languages);
  const otherLang = langKeys.find((l) => l !== currentLang) ?? langKeys[0];
  otherLangLabel = languages[otherLang];
  const pathWithoutLang = currentPath.replace(new RegExp(`^\\/(${langKeys.join('|')})`), '') || '/';
  switchUrl = otherLang === defaultLang ? pathWithoutLang : `/${otherLang}${pathWithoutLang}`;
}
---

<header class={`fixed top-0 left-0 right-0 z-50 ${headerBgClass} backdrop-blur-lg border-b border-slate-200 dark:border-slate-800`}>
  <!-- Hidden checkbox for CSS-only mobile menu toggle -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden" aria-hidden="true" />
  <nav class="mx-auto w-full max-w-6xl px-4 sm:px-6 flex items-center justify-between h-16" aria-label="Main navigation">
    <a href={homeHref} class="flex items-center gap-2 font-bold text-xl text-slate-900 dark:text-white">
      <img src={brandLogoSrc} alt="" class="h-8 w-8 object-contain" />
      {brandTextSegments ? (
        brandTextSegmentsDark ? (
          <Fragment>
            <span class="dark:hidden">
              {brandTextSegments.map(seg => (
                <span style={`color: ${seg.color}; font-weight: ${seg.fontWeight || 'inherit'}`}>{seg.text}</span>
              ))}
            </span>
            <span class="hidden dark:inline">
              {brandTextSegmentsDark.map(seg => (
                <span style={`color: ${seg.color}; font-weight: ${seg.fontWeight || 'inherit'}`}>{seg.text}</span>
              ))}
            </span>
          </Fragment>
        ) : (
          <span>
            {brandTextSegments.map(seg => (
              <span style={`color: ${seg.color}; font-weight: ${seg.fontWeight || 'inherit'}`}>{seg.text}</span>
            ))}
          </span>
        )
      ) : (
        <slot name="brand-text">
          <span class={`bg-gradient-to-r ${brandGradient} bg-clip-text text-transparent`}>{brandName}</span>
        </slot>
      )}
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navItems.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-blue-600 dark:hover:text-blue-400',
              currentPath === href || currentPath === `${href}/`
                ? 'text-blue-600 dark:text-blue-400'
                : 'text-slate-600 dark:text-slate-400',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <slot name="header-extra" />
      {hasI18n && (
        <a
          href={switchUrl}
          class="text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors px-2 py-1 border border-slate-200 dark:border-slate-700 rounded"
        >
          {otherLangLabel}
        </a>
      )}
      {signInLabel && signInHref && (
        <a
          href={signInHref}
          class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors"
        >
          {signInLabel}
        </a>
      )}
      {ctaLabel && ctaHref && (
        <a
          href={ctaHref}
          class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors"
        >
          {ctaLabel}
        </a>
      )}
    </div>

    <!-- Mobile menu label -->
    <label for="mobile-menu-toggle" class="md:hidden p-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white cursor-pointer" aria-label="Toggle navigation menu">
      <svg class="mobile-menu-open w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg class="mobile-menu-close w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </label>
  </nav>

  <!-- Mobile menu -->
  <div class="mobile-menu-panel border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900">
    <ul class="px-4 py-4 space-y-2">
      {navItems.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              currentPath === href || currentPath === `${href}/`
                ? 'text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20'
                : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      {(signInLabel && signInHref) || hasI18n ? (
        <li class="pt-2 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
          {signInLabel && signInHref && (
            <a href={signInHref} class="block px-3 py-2 text-sm font-medium text-slate-600 dark:text-slate-400">
              {signInLabel}
            </a>
          )}
          {hasI18n && (
            <a href={switchUrl} class="text-xs font-medium text-slate-500 px-2 py-1 border border-slate-200 dark:border-slate-700 rounded">
              {otherLangLabel}
            </a>
          )}
        </li>
      ) : null}
      {ctaLabel && ctaHref && (
        <li>
          <a href={ctaHref} class="block px-3 py-2 text-sm font-semibold text-blue-600 dark:text-blue-400">
            {ctaLabel}
          </a>
        </li>
      )}
    </ul>
  </div>
</header>

<style is:global>
  .mobile-menu-close,
  .mobile-menu-panel { display: none; }
  #mobile-menu-toggle:checked ~ nav .mobile-menu-open { display: none; }
  #mobile-menu-toggle:checked ~ nav .mobile-menu-close { display: block; }
  #mobile-menu-toggle:checked ~ .mobile-menu-panel { display: block; }
  @media (min-width: 768px) {
    .mobile-menu-panel { display: none !important; }
  }
</style>
